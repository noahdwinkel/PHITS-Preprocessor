{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PHITS",
  "scopeName": "source.phits",
  "patterns": [
    { "include": "#comments" },
    { "include": "#sections" },
    { "include": "#directives" },
    { "include": "#parameters" },
    { "include": "#particles" },
    { "include": "#geometry" },
    { "include": "#numbers" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.phits", "match": "^\\s*[#!].*$" },
        { "name": "comment.line.phits", "match": "^[cC]\\s+.*$" },
        { "name": "comment.line.phits", "match": "\\$(?!RWT\\s*=).*?$" }
      ]
    },

    "sections": {
      "patterns": [
        {
          "name": "keyword.control.section.phits",
          "match": "\\[(?i:(title|cell|surface|material|parameters|source|transform|end|t-track|p-track|e-track|n-track|mat\\s+name\\s+color))\\]"
        }
      ]
    },

    "directives": {
      "patterns": [
        { "name": "keyword.control.directive.phits", "match": "\\$RWT\\s*=\\s*\\d+" }
      ]
    },

    "parameters": {
      "patterns": [
        {
          "name": "support.type.parameter.phits",
          "match": "\\b(icntl|maxcas|maxbch|maxbnk|maxtrk|maxhis|istdev|timeout|iflux|iprn|ierr|isw|seed)\\b"
        }
      ]
    },

    "particles": {
      "patterns": [
        { "name": "support.constant.particle.phits", "match": "\\b(neutron|proton|photon|electron|positron|deuteron|triton|alpha|muon|pion|kaon|ion)\\b" }
      ]
    },

    "geometry": {
      "patterns": [
        { "name": "support.class.macrobody.phits", "match": "\\b(?i:(RPP|BOX|SPH|RCC|REC|ELL|TRC|WED|ARB))\\b" },
        { "name": "support.class.surface.phits",   "match": "\\b(?i:(S|P|PX|PY|PZ|SO|SX|SY|SZ|C/X|C/Y|C/Z))\\b" }
      ]
    },

    "numbers": {
      "patterns": [
        { "name": "constant.numeric.phits", "match": "[+-]?(\\d+\\.\\d*|\\.\\d+|\\d+)([eE][+-]?\\d+)?" }
      ]
    },

    "variables": {
      "patterns": [
        {
          "name": "keyword.other.set.phits",
          "match": "\\b(?i:set:)\\b"
        },
        {
          "name": "meta.variable.definition.phits",
          "begin": "\\b(?i:set:)\\b\\s*",
          "end": "(?=\\[|\\s|$)",
          "patterns": [
            {
              "name": "entity.name.variable.phits",
              "match": "[a-zA-Z_][a-zA-Z0-9_]*"
            }
          ]
        },
        {
          "name": "variable.other.reference.phits",
          "match": "\\b[cC]\\d+\\b"
        },

        { "name": "variable.other.identifier.phits", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b" }
      ]
    },

    "operators": {
      "patterns": [
        { "name": "keyword.operator.boolean.phits", "match": "[#:]" },
        { "name": "keyword.operator.arithmetic.phits", "match": "[+\\-*/=()]" }
      ]
    }
  }
}